generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  email        String   @id
  name         String?
  avatar       String?
  createdAt    DateTime @default(now())

  items            Item[]             @relation("owner")
  sentRequests     Friendship[]       @relation("sender")
  receivedRequests Friendship[]       @relation("receiver")
  shares           Share[]
  memberships      SharedMembership[] @relation("adder")
}

model Item {
  id          String   @id @default(uuid())
  ownerEmail  String
  title       String
  url         String?
  summary     String
  category    String
  subcategory String
  tags        String[]
  dateAdded   DateTime @default(now())
  content     String?
  source      String
  read        Boolean  @default(false)
  color       String?
  sortOrder   Int?
  sharedOnly  Boolean  @default(false) // true = not shown in personal library, only via SharedMembership
  attachments Json?    // [{ url, type: "image"|"pdf", name, size }]

  owner       User               @relation("owner", fields: [ownerEmail], references: [email])
  memberships SharedMembership[]

  @@index([ownerEmail, category])
}

model SharedMembership {
  id      String   @id @default(uuid())
  itemId  String
  shareId String
  addedBy String
  addedAt DateTime @default(now())

  item  Item  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  share Share @relation(fields: [shareId], references: [id], onDelete: Cascade)
  adder User  @relation("adder", fields: [addedBy], references: [email])

  @@unique([itemId, shareId])
  @@index([shareId])
}

model Friendship {
  id         String    @id @default(uuid())
  fromEmail  String
  toEmail    String
  status     String    @default("pending") // "pending" | "accepted" | "declined"
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  sender   User @relation("sender", fields: [fromEmail], references: [email])
  receiver User @relation("receiver", fields: [toEmail], references: [email])

  @@unique([fromEmail, toEmail])
  @@index([toEmail, status])
}

model Share {
  id            String   @id @default(uuid())
  ownerEmail    String
  categoryName  String
  mode          String // "whitelist" | "public"
  allowedEmails String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  owner       User               @relation(fields: [ownerEmail], references: [email])
  memberships SharedMembership[]

  @@unique([ownerEmail, categoryName])
  @@index([mode])
}
