generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  email         String   @id
  name          String?
  avatar        String?
  createdAt     DateTime @default(now())
  weeklyDigest  Boolean  @default(true)
  tourCompleted Boolean  @default(false)

  items            Item[]             @relation("owner")
  sentRequests     Friendship[]       @relation("sender")
  receivedRequests Friendship[]       @relation("receiver")
  shares           Share[]
  memberships      SharedMembership[] @relation("adder")
  itemReads         UserItemRead[]
  ratings           ItemRating[]
  comments          ItemComment[]
  categoryNotes     CategoryNote[]
  categoryIcons     CategoryIcon[]
  collections       Collection[]
  pushSubscriptions PushSubscription[]
}

// Scratch-pad notes per category (personal only)
model CategoryNote {
  ownerEmail   String
  categoryName String
  content      String   @default("")
  updatedAt    DateTime @updatedAt

  owner User @relation(fields: [ownerEmail], references: [email], onDelete: Cascade)

  @@id([ownerEmail, categoryName])
}

// Per-user read tracking for shared library viewers (owner uses Item.read)
model UserItemRead {
  userEmail String
  itemId    String
  readAt    DateTime @default(now())

  user User @relation(fields: [userEmail], references: [email], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([userEmail, itemId])
  @@index([itemId])
}

// Star rating (1–5) per user per item
model ItemRating {
  userEmail String
  itemId    String
  rating    Int
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userEmail], references: [email], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([userEmail, itemId])
  @@index([itemId])
}

// Comments on items
model ItemComment {
  id        String   @id @default(uuid())
  itemId    String
  userEmail String
  userName  String?
  content   String
  createdAt DateTime @default(now())

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userEmail], references: [email], onDelete: Cascade)

  @@index([itemId])
}

model Item {
  id          String   @id @default(uuid())
  ownerEmail  String
  title       String
  url         String?
  summary     String
  category    String
  subcategory String
  tags        String[]
  dateAdded   DateTime @default(now())
  content     String?
  source      String
  read        Boolean  @default(false)
  color       String?
  sortOrder   Int?
  sharedOnly  Boolean  @default(false) // true = not shown in personal library, only via SharedMembership
  attachments Json?    // [{ url, type: "image"|"pdf", name, size }]

  owner       User               @relation("owner", fields: [ownerEmail], references: [email])
  memberships SharedMembership[]
  userReads   UserItemRead[]
  ratings     ItemRating[]
  comments    ItemComment[]
  collections CollectionItem[]

  @@index([ownerEmail, category])
}

// Cross-category curated collections
model Collection {
  id          String   @id @default(uuid())
  ownerEmail  String
  name        String
  description String?
  color       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner User            @relation(fields: [ownerEmail], references: [email], onDelete: Cascade)
  items CollectionItem[]

  @@unique([ownerEmail, name])
  @@index([ownerEmail])
}

model CollectionItem {
  id           String   @id @default(uuid())
  collectionId String
  itemId       String
  addedAt      DateTime @default(now())

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  item       Item       @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([collectionId, itemId])
  @@index([collectionId])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userEmail String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userEmail], references: [email], onDelete: Cascade)

  @@index([userEmail])
}

model Notification {
  id           String   @id @default(uuid())
  toEmail      String
  fromEmail    String
  fromName     String?
  type         String   // "item_shared"
  itemId       String?
  itemTitle    String?
  shareId      String?
  categoryName String?
  read         Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([toEmail, read])
  @@index([toEmail, createdAt])
}

model SharedMembership {
  id      String   @id @default(uuid())
  itemId  String
  shareId String
  addedBy String
  addedAt DateTime @default(now())

  item  Item  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  share Share @relation(fields: [shareId], references: [id], onDelete: Cascade)
  adder User  @relation("adder", fields: [addedBy], references: [email])

  @@unique([itemId, shareId])
  @@index([shareId])
}

model Friendship {
  id         String    @id @default(uuid())
  fromEmail  String
  toEmail    String
  status     String    @default("pending") // "pending" | "accepted" | "declined"
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  sender   User @relation("sender", fields: [fromEmail], references: [email])
  receiver User @relation("receiver", fields: [toEmail], references: [email])

  @@unique([fromEmail, toEmail])
  @@index([toEmail, status])
}

model CategoryIcon {
  ownerEmail   String
  categoryName String
  icon         String

  owner User @relation(fields: [ownerEmail], references: [email], onDelete: Cascade)

  @@id([ownerEmail, categoryName])
}

model Share {
  id            String   @id @default(uuid())
  ownerEmail    String
  categoryName  String
  mode          String // "whitelist" | "public"
  allowedEmails String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  owner       User               @relation(fields: [ownerEmail], references: [email])
  memberships SharedMembership[]

  @@unique([ownerEmail, categoryName])
  @@index([mode])
}
